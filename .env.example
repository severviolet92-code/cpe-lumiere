# ============================================================================
# CPE Lumière — environment configuration
# Copy to .env and fill in. Everything marked "optional" can be left unset in
# development; the app degrades gracefully (see /api/system-health for live
# status of each subsystem). Nothing here contains a real secret — these are
# placeholders. See PRODUCTION_ACTIVATION_CHECKLIST.md for what production needs.
# ============================================================================

# --- Core (required) -------------------------------------------------------
# Generate PAYLOAD_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER reuse the development secret in production.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Dev (SQLite):          DATABASE_URI=file:./cpe-lumiere.db
# Production (Postgres): DATABASE_URI=postgres://user:pass@host:5432/dbname
# (In production also switch the adapter in src/payload.config.ts to
#  postgresAdapter — see the comment there; the package is already installed.)
DATABASE_URI=file:./cpe-lumiere.db

# Public base URL — used by robots.txt, sitemap.xml, and magic-link emails.
# Set to the real https:// domain in production.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Email (optional in dev) -----------------------------------------------
# Without RESEND_API_KEY, all email is written to the server console instead of
# being sent (fine for the demo; the system-health page flags this as degraded).
# In production, configure Resend (or swap the mailer/adapter) WITH SPF/DKIM/
# DMARC on the CPE's real domain.
# RESEND_API_KEY=
# CONTACT_EMAIL_FROM=bonjour@your-cpe-domain.example
# CONTACT_EMAIL_TO=admin@your-cpe-domain.example

# --- Campaign scheduling (optional) ----------------------------------------
# By default the app checks for due scheduled campaigns every few minutes while
# running (single-instance — no external cron needed). Once you run more than
# one instance, set CAMPAIGN_SCHEDULER=external and point a real cron at
# POST /api/email-campaigns/run-due with Authorization: Bearer $CAMPAIGN_CRON_SECRET.
# CAMPAIGN_SCHEDULER=external
# CAMPAIGN_SCHEDULER_INTERVAL_MINUTES=5
# CAMPAIGN_CRON_SECRET=

# --- Observability / error reporting (optional, disabled until set) ---------
# When ERROR_REPORTING_WEBHOOK_URL is set, every captured error is also POSTed
# there as a JSON envelope (provider-agnostic: point it at a Sentry ingest
# proxy, a log drain, a serverless function, etc.). When unset, errors are
# structured-logged locally and shown on /api/system-health only.
# ERROR_REPORTING_WEBHOOK_URL=
