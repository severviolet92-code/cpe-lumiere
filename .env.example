# Copy to .env and fill in. Generate PAYLOAD_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Dev (SQLite):          DATABASE_URI=file:./cpe-lumiere.db
# Production (Postgres): DATABASE_URI=postgres://user:pass@host:5432/dbname
DATABASE_URI=file:./cpe-lumiere.db
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Email (optional in dev — without a key, emails are logged to the console)
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=
# CONTACT_EMAIL_FROM=
# Secret for the scheduled-campaign runner (POST /api/email-campaigns/run-due),
# needed only if an external cron calls it (see CAMPAIGN_SCHEDULER below)
# CAMPAIGN_CRON_SECRET=

# Campaign scheduling: by default the app itself checks for due campaigns
# every few minutes while it's running (single-instance deployments — no
# external cron needed). Set to "external" once you run more than one
# instance, and point a real cron/scheduler at POST /api/email-campaigns/run-due
# with Authorization: Bearer $CAMPAIGN_CRON_SECRET instead.
# CAMPAIGN_SCHEDULER=external
# CAMPAIGN_SCHEDULER_INTERVAL_MINUTES=5
