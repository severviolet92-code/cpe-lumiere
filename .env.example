# Copy to .env and fill in. Generate PAYLOAD_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Dev (SQLite):          DATABASE_URI=file:./cpe-lumiere.db
# Production (Postgres): DATABASE_URI=postgres://user:pass@host:5432/dbname
DATABASE_URI=file:./cpe-lumiere.db
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Email (optional in dev — without a key, emails are logged to the console)
# RESEND_API_KEY=
# CONTACT_EMAIL_TO=
# CONTACT_EMAIL_FROM=
# Secret for the scheduled-campaign runner (POST /api/email-campaigns/run-due)
# CAMPAIGN_CRON_SECRET=
