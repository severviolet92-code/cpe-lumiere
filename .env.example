# Copy to .env and fill in. Generate PAYLOAD_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Dev (SQLite):          DATABASE_URI=file:./cpe-lumiere.db
# Production (Postgres): DATABASE_URI=postgres://user:pass@host:5432/dbname
DATABASE_URI=file:./cpe-lumiere.db
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
